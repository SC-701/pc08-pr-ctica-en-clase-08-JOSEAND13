@page
@model Web.Pages.Productos.IndexModel
@{
}
<h1>Listado de Productos</h1>
<div class="container">
    <div class="text-center mb-4">
        <a type="button" class="btn btn-primary" asp-page="./Agregar">Agregar</a>
    </div>
    <div class="row">
    @if (Model.productos != null)
            @foreach (var vehiculo in Model.productos)
        {
            <div class="col-md-4 mb-4">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">@Html.DisplayFor(modelo => vehiculo.Nombre)</h5>
                        <h6 class="card-subtitle mb-2 text-muted">@Html.DisplayFor(modelo => vehiculo.Precio)</h6>
                            <p class="card-text"><strong>Categoría:</strong> @Html.DisplayFor(modelo => vehiculo.Categoria) - <strong>SubCategoría:</strong> @Html.DisplayFor(modelo => vehiculo.SubCategoria)</p>
                        <a type="button" class="btn btn-primary" asp-page="./Detalle" asp-route-id="@vehiculo.Id">Detalle</a>
                        <a type="button" class="btn btn-warning" asp-page="./Editar" asp-route-id="@vehiculo.Id">Editar</a>
                        <a type="button" class="btn btn-danger" asp-page="./Eliminar" asp-route-id="@vehiculo.Id">Eliminar</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
